PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/<db-name>
MAX_UPLOAD_SIZE_MB=50
FILE_RETENTION_HOURS=3
# Optional: set when LibreOffice exists at a custom location on your host/container.
LIBREOFFICE_PATH=/usr/bin/soffice
# Comma-separated list of allowed frontend origins. Use * only when intentionally open.
CORS_ORIGINS=http://localhost:5173,https://your-frontend-domain.com
STUDENT_DRIVE_JWT_SECRET=replace-with-a-strong-random-secret
